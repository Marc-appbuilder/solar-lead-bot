# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (Nodemailer) — works with Gmail, Mailgun, SendGrid, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="EstateAssist <you@gmail.com>"

# Public URL of this app (used in embed.js instructions)
NEXT_PUBLIC_APP_URL=https://your-domain.com
